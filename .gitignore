# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
.env.*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# debug/test scripts
check_internships.js
debug_internships.js
test_api.js

# test scripts
scripts/test_*.py
scripts/test_*.js
scripts/test_*.mjs

# scraped data (optional - uncomment if you don't want to commit scraped data)
data/internships_*.json

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

.git